# PostgreSQL connection (required in production)
DATABASE_URL=postgresql://ndecc:your_password@localhost:5432/ndecc_sched

# Server port
PORT=5001

# HubSpot Private App access token (optional — registration list won't work without it)
HUBSPOT_API_KEY=

# JWT secret for auth tokens (required in production — use a long random string)
JWT_SECRET=

# Bcrypt hash of admin password (required in production)
# Generate with: node -e "require('bcryptjs').hash('YOUR_PASSWORD', 10).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=
