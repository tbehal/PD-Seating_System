    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.14",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.27",
    "prettier": "^3.4.0",
    "tailwindcss": "^3.3.3",
    "vitest": "^4.0.18"
  }
